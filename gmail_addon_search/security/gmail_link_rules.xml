<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="gmail_email_link_company_rule" model="ir.rule">
        <field name="name">gmail.email.link: multi-company</field>
        <field name="model_id" ref="model_gmail_email_link"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="gmail_document_link_company_rule" model="ir.rule">
        <field name="name">gmail.document.link: multi-company</field>
        <field name="model_id" ref="model_gmail_document_link"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
